+def _dedupe_key(candidate: CandidateEvent) -> str:
+    return sha256(f"{candidate.domain.value}|{candidate.event_type}|{candidate.subject_id}|{candidate.source_record_id}".encode("utf-8")).hexdigest()[:24]
