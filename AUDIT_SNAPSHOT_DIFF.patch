+            "endOfWeekForecast": float(_money(today * Decimal("5"))),
+            "endOfMonthForecast": float(_money(today * Decimal("21"))),
+            "estimatedExhaustionTime": "not_forecast" if utilization < Decimal("0.75") else "within_current_period",
