+def _allowed_sessions(requirement: str) -> set[str]:
+    if requirement == "Any":
+        return {"Pre-Market", "Regular", "After-Hours", "Closed", "Continuous"}
+    if requirement == "Market Hours":
+        return {"Regular"}
+    return {requirement}
