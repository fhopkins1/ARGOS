+            for benchmark_id, benchmark_name in (("BENCH-CASH", "Cash"), ("BENCH-SPY", "SPY"), ("BENCH-QQQ", "QQQ"), ("BENCH-SECTOR", "Relevant Sector ETF"), ("BENCH-NOTRADE", "No Trade"), ("BENCH-PREV", "Previous Strategy"), ("BENCH-RANDOM", "Random Entry Baseline")):
