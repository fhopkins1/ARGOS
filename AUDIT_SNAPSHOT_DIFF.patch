+def _next_version(version: str, offset: int) -> str:
+    parts = [int(part) for part in version.split(".") if part.isdigit()]
+    if not parts:
+        return f"1.0.{offset}"
+    while len(parts) < 3:
+        parts.append(0)
+    parts[2] += offset
+    return ".".join(str(part) for part in parts[:3])
