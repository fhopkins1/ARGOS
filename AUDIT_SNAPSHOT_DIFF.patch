+        self._audit.append(
+            MessageAuditRecord(
+                f"ECL-AUD-{len(self._audit) + 1:06d}",
+                utc_timestamp(),
+                "subscriber_registered",
+                "",
+                "",
+                subscription.subscription_id,
+                "",
+                subscription.subscriber_service_id,
+                "",
+                "",
+                "",
+                "",
+                "",
