+def _envelope_from_public(item: dict[str, Any]) -> EnterpriseMessageEnvelope:
+    data = dict(item)
+    data["message_kind"] = EnterpriseMessageKind(data["message_kind"])
+    data["paper_live_mode"] = MessageMode(data["paper_live_mode"])
