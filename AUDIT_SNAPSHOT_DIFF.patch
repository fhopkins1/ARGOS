+        window_end: str = "latest_state_snapshot",
+        mode: str = "COMBINED",
+        persist: bool = False,
+    ) -> dict[str, Any]:
+        generated_at = utc_timestamp()
+        values = self._calculate_values(sources, window_start, window_end, mode, generated_at)
