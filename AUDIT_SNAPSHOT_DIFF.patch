+    def run_campaign(self, *, cycles: int = 3) -> CertificationCampaignResult:
+        runtime = CanonicalEnterpriseRuntime()
+        start_status = runtime.start()
+        admissions = []
+        for day_offset in range(max(1, cycles)):
